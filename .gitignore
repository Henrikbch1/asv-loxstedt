# Directus Core & Environment
cms/.env
cms/.env.*
cms/node_modules/

cms/database/*.db
cms/database/*.sqlite
cms/uploads/*

!cms/database/.gitkeep
!cms/uploads/.gitkeep

# Extensions
!cms/extensions/
cms/extensions/.gitkeep

# Frontend / Cypress / Dev artifacts
# frontend build & deps (frontend has its own .gitignore but keep root safe)
frontend/node_modules/
frontend/dist/
frontend/.env

# JetBrains IDEA
.idea/

# Cypress artefacts (frontend tests)
frontend/cypress/videos/
frontend/cypress/screenshots/
frontend/cypress/reports/

# Local env / secrets
frontend/cypress.env.json
frontend/.env.local

# Coverage / test output
frontend/coverage/
.nyc_output/
coverage/

# Testing coverage
coverage/
